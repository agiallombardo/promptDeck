# Sample nginx site for promptDeck on a single machine (local / LAN, no public domain).
# Users open http://SERVER_IP/ or http://hostname.local/ — use that exact origin in
# PUBLIC_APP_URL and CORS_ORIGINS (see docs/UBUNTU_SERVER_SETUP.md §7).

upstream promptdeck_api {
    server 127.0.0.1:8005;
    keepalive 32;
}

server {
    listen 80;
    # Single-site LAN: catch-all. Optionally set server_name to the host's IP or .local name.
    server_name _;

    client_max_body_size 12m;

    root /opt/promptDeck/frontend/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://promptdeck_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /a/ {
        proxy_pass http://promptdeck_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /health {
        proxy_pass http://promptdeck_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }
}

# Optional — only if you terminate HTTPS (internal CA, reverse proxy with certs, or a real domain + Let’s Encrypt):
# server {
#     listen 443 ssl http2;
#     server_name your.hostname;
#     ssl_certificate     /path/to/fullchain.pem;
#     ssl_certificate_key /path/to/privkey.pem;
#     ... same location blocks as above ...
# }
