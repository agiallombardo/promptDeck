# Example variables for root `docker-compose.yml`. Copy to `.env` beside that file
# or export before `docker compose up`. Never commit real secrets.

JWT_SECRET_KEY=replace-with-openssl-rand-hex-32

# Must match how users open the UI (scheme + host + port).
PUBLIC_APP_URL=http://127.0.0.1:8080
PUBLIC_API_URL=http://127.0.0.1:8080

# Microsoft Entra (optional). Redirect URI in Entra must be exactly:
#   ${PUBLIC_API_URL}/api/v1/auth/entra/callback
# ENTRA_ENABLED=true
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# COOKIE_SECURE=true
