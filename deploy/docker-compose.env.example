# Example variables for root `docker-compose.yml`. Copy to `.env` beside `docker-compose.yml`:
#   cp deploy/docker-compose.env.example .env
# Never commit real secrets.

JWT_SECRET_KEY=replace-with-openssl-rand-hex-32
ASSET_SIGNING_KEY=

DATABASE_URL=sqlite+aiosqlite:////data/promptdeck.db
STORAGE_ROOT=/data/storage
STATIC_SITE_DIR=/app/backend/static/site

ENVIRONMENT=production

# Must match how users open the UI (scheme + host + port). Defaults align with PROMPTDECK_HTTP_PORT=8080.
PUBLIC_APP_URL=http://127.0.0.1:8080
PUBLIC_API_URL=http://127.0.0.1:8080

# JSON array of allowed browser origins — include the same origin as PUBLIC_APP_URL.
CORS_ORIGINS=["http://127.0.0.1:8080"]

# Microsoft Entra (optional). Redirect URI in Entra must be exactly:
#   ${PUBLIC_API_URL}/api/v1/auth/entra/callback
# ENTRA_ENABLED=true
# ENTRA_TENANT_ID=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# COOKIE_SECURE=true

# Deck LLM (optional; same keys as backend/.env.example — configure for AI deck/diagram features).
# DECK_LLM_PROVIDER=litellm
# LITELLM_API_BASE=
# LITELLM_API_KEY=
