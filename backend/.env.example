# Copy to `.env` for local development (never commit secrets).

DATABASE_URL=postgresql+asyncpg://promptdeck:promptdeck@127.0.0.1:5432/promptdeck
JWT_SECRET_KEY=dev-change-me-use-openssl-rand-hex-32
ENVIRONMENT=development
STORAGE_ROOT=./data/storage
ASSET_SIGNING_KEY=dev-asset-signing-key-change-me

# Optional Argon2id tuning (defaults are sane for dev)
# ARGON2_TIME_COST=3
# ARGON2_MEMORY_COST=65536
# ARGON2_PARALLELISM=1

# Initial login users (scripts/bootstrap_users.py; not used by the API at runtime)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=changeme123
# BOOTSTRAP_EDITOR_EMAIL=editor@example.com
# BOOTSTRAP_EDITOR_PASSWORD=changeme123
# BOOTSTRAP_DEMO_USERS=0   # omit editor; 1 forces editor even outside development
