# Copy to `.env` for local development (never commit secrets).

DATABASE_URL=postgresql+asyncpg://promptdeck:promptdeck@127.0.0.1:5432/promptdeck
JWT_SECRET_KEY=dev-change-me-use-openssl-rand-hex-32
ENVIRONMENT=development
STORAGE_ROOT=./data/storage
ASSET_SIGNING_KEY=dev-asset-signing-key-change-me
PUBLIC_APP_URL=http://127.0.0.1:5174
PUBLIC_API_URL=http://127.0.0.1:8005

# Auth mode
LOCAL_PASSWORD_AUTH_ENABLED=true
ENTRA_ENABLED=false
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Optional: base64 Fernet key for encrypting stored Entra refresh tokens.
# If omitted, the app derives one from JWT_SECRET_KEY.
ENTRA_TOKEN_ENCRYPTION_KEY=

# Optional SMTP (Microsoft 365: host smtp.office365.com, port 587, STARTTLS on, implicit TLS off)
# Admin UI can override these via system_settings (password stored encrypted in DB).
# SMTP_ENABLED=false
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_STARTTLS=true
# SMTP_IMPLICIT_TLS=false
# SMTP_VALIDATE_CERTS=true
# SMTP_AUTH_MODE=login
#   Use `none` only for trusted internal relays (no SMTP AUTH); still requires TLS.

# Optional LiteLLM / OpenAI-compatible proxy (system default; admin UI can override base URL in DB)
# LITELLM_API_BASE=https://litellm.example.com/v1
# Model id for deck prompt edits (OpenAI-compatible)
# DECK_LLM_MODEL=gpt-4o-mini

# Optional Argon2id tuning (defaults are sane for dev)
# ARGON2_TIME_COST=3
# ARGON2_MEMORY_COST=65536
# ARGON2_PARALLELISM=1

# Initial local login users for dev/test only (scripts/bootstrap_users.py)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=changeme123
# BOOTSTRAP_USER_EMAIL=user@example.com
# BOOTSTRAP_USER_PASSWORD=changeme123
# BOOTSTRAP_DEMO_USERS=0
