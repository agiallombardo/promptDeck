{
  "name": "promptdeck-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . && prettier --check \"src/**/*.{ts,tsx,css}\" index.html",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" index.html",
    "test": "vitest",
    "test:run": "vitest run",
    "tsc": "tsc --noEmit",
    "api:contract": "openapi-typescript ../backend/openapi.json -o src/lib/api/schema.d.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.62.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.4",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.19.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
